# Copy to .env and fill before deployment.

# Build / image
GRAPHCLAW_BUILD_TARGET=release
GRAPHCLAW_CARGO_FEATURES=memory-postgres
GRAPHCLAW_IMAGE=graphclaw-highfinity:local

# Gateway exposure
HOST_GATEWAY_PORT=42617
ZEROCLAW_GATEWAY_PORT=42617
RUST_LOG=info

# Model/provider credentials
ZEROCLAW_API_KEY=
ZEROCLAW_PROVIDER=openai-codex
ZEROCLAW_MODEL=gpt-5.4

# Cloudflare Tunnel
CLOUDFLARE_TUNNEL_TOKEN=
GRAPHCLAW_PUBLIC_HOSTNAME=graphclaw.highfinity.internal

# PostgreSQL
POSTGRES_DB=graphclaw
POSTGRES_USER=graphclaw
POSTGRES_PASSWORD=change-me-long-random-secret
ZEROCLAW_STORAGE_PROVIDER=postgres
ZEROCLAW_STORAGE_CONNECT_TIMEOUT_SECS=15
